# Default configuration for LANAgent systemd service.
# Copy this file to /etc/lanagent/lanagent.conf and adjust as needed.

# Port where LANAgent listens for HTTP requests. 0 means auto-select.
LANAGENT_PORT=0

# Seconds between periodic ARP scans.
LANAGENT_SCAN_INTERVAL=60

# Presence thresholds. Ordinary devices are marked gone after presence grace;
# sleep-tolerant devices, such as private-MAC mobile clients, use sleep grace.
LANAGENT_PRESENCE_GRACE=1800
LANAGENT_SLEEP_GRACE=43200
LANAGENT_MISS_COUNT=3

# Suppress leave events when a scan sees less than this fraction of the
# currently expected present devices.
LANAGENT_MIN_PROBE_COMPLETENESS=0.35

# Treat a long service scheduling gap as local suspend/resume and ignore that
# local pause in absence timers.
LANAGENT_RESUME_GAP=300
